# Backend config
ENV=dev
FRONTEND_ORIGIN=http://localhost:3000

# Database (Postgres)
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/portal

# JWT
JWT_SECRET=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7 days

# Upload storage
UPLOAD_DIR=./app/uploads
MAX_UPLOAD_MB=15
